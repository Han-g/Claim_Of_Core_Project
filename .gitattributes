# Normalize text files in the repository, then pin common project files below.
* text=auto

# C++ source files: keep LF in the working tree across Windows and non-Windows tools.
*.c      text eol=lf
*.cc     text eol=lf
*.cpp    text eol=lf
*.cxx    text eol=lf
*.h      text eol=lf
*.hh     text eol=lf
*.hpp    text eol=lf
*.hxx    text eol=lf
*.inl    text eol=lf
*.ipp    text eol=lf

# Unreal Engine / C# / config / documentation text files.
*.cs           text eol=lf
*.Build.cs     text eol=lf
*.Target.cs    text eol=lf
*.ini          text eol=lf
*.json         text eol=lf
*.uproject     text eol=lf
*.uplugin      text eol=lf
*.md           text eol=lf
*.txt          text eol=lf
*.gitignore    text eol=lf
*.gitattributes text eol=lf

# Visual Studio / MSBuild files are Windows-generated, so keep CRLF.
*.sln            text eol=crlf
*.vcxproj        text eol=crlf
*.vcxproj.filters text eol=crlf
*.vcxproj.user   text eol=crlf
*.props          text eol=crlf
*.targets        text eol=crlf

# Windows scripts.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unreal and packaged binary assets must never be line-ending normalized.
*.uasset binary
*.umap   binary
*.ubulk  binary
*.uexp   binary
*.utoc   binary

# Existing Git LFS rule.
*.ucas filter=lfs diff=lfs merge=lfs -text

# Common binary assets.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.bmp  binary
*.tga  binary
*.wav  binary
*.mp3  binary
*.ogg  binary
*.mp4  binary
*.fbx  binary
*.dll  binary
*.exe  binary
*.lib  binary
*.pdb  binary
*.zip  binary
*.7z   binary
